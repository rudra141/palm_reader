# =====================================================================
# Praxa — environment variable template
# Copy to .env.local for local dev. Never commit .env.local.
# Production values set in Vercel dashboard.
# =====================================================================

# --- AI providers (Phase 4) -------------------------------------------
# Anthropic — primary (vision: claude-sonnet-4-6, reasoning: claude-opus-4-7, filter: claude-haiku-4-5-20251001)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Fallback chain (optional but recommended)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
GOOGLE_GENERATIVE_AI_API_KEY=xxxxxxxxxxxxxxxx

# --- Storage (Phase 4) ------------------------------------------------
# Vercel Blob — hand-photo storage with signed URLs, 24h default TTL
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# --- Database (Phase 9) -----------------------------------------------
# Supabase Postgres connection string
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# --- Auth (Phase 9) ---------------------------------------------------
# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Rate limits + cost counters (Phase 4) ----------------------------
# Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxx

# --- Bot defense (Phase 11) -------------------------------------------
# Cloudflare Turnstile on /api/upload
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAxxxxxxxxx

# --- Observability (Phase 2 onward) -----------------------------------
# Sentry
SENTRY_DSN=https://xxxxxxx@xxx.ingest.sentry.io/xxxxxxx
NEXT_PUBLIC_SENTRY_DSN=$SENTRY_DSN
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Cost guards (Phase 4) --------------------------------------------
# System-wide monthly cap before auto-degrade fires (Opus → Sonnet)
MONTHLY_COST_CAP_USD=500
# Per-user daily cap (used by Upstash counter)
PER_USER_DAILY_CAP_USD=5

# --- Feature flags (Phase 9 / v1.1) -----------------------------------
# Subscription rollout — keep false at v1; flip to true when v1.1 ships
SUBSCRIPTION_ENABLED=false

# --- Stripe (only when SUBSCRIPTION_ENABLED=true; Phase 9 v1.1) -------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Public site -------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin gate --------------------------------------------------------
# Comma-separated Clerk user IDs allowed at /admin/costs
ADMIN_CLERK_USER_IDS=
